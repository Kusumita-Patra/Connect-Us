<!DOCTYPE html>
<html>
<head>
  <title>Campus Marketplace</title>
</head>
<body>

<h2>📦 Campus Marketplace</h2>

<!-- Search + Category -->
<input type="text" id="search" placeholder="Search item...">

<select id="category">
  <option value="All">All</option>
  <option value="Books">Books</option>
  <option value="Electronics">Electronics</option>
  <option value="Lab Equipment">Lab Equipment</option>
  <option value="Hostel Items">Hostel Items</option>
</select>

<button onclick="loadItems()">Search</button>

<br><br>
<a href="upload.html">➕ Upload Item</a>

<hr>

<div id="items"></div>

<!-- Firebase SDK -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js"></script>

<script>
  // 🔥 YOUR FIREBASE CONFIG
  const firebaseConfig = {
    apiKey: "YOUR_KEY",
    authDomain: "YOUR_DOMAIN",
    projectId: "YOUR_PROJECT_ID"
  };

  const app = firebase.initializeApp(firebaseConfig);
  const db = firebase.firestore();

  async function loadItems() {
    let search = document.getElementById("search").value.toLowerCase();
    let category = document.getElementById("category").value;

    let snapshot = await db.collection("items").get();

    let output = "";

    snapshot.forEach(doc => {
      let data = doc.data();

      if ((category === "All" || data.category === category) &&
          data.name.toLowerCase().includes(search)) {

        output += `
          <div style="border:1px solid black; margin:10px; padding:10px;">
            <b>${data.name}</b><br>
            ₹${data.price}<br>
            Category: ${data.category}
          </div>
        `;
      }
    });

    document.getElementById("items").innerHTML = output;
  }

  loadItems();
</script>

</body>
</html>
